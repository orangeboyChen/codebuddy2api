# Optional service password for the OpenAI-compatible API
CODEBUDDY_PASSWORD=

# Authentication mode:
# - auto: prefer API key, otherwise use saved credentials
# - api_key: force API key mode
# - token: force saved credential mode
CODEBUDDY_AUTH_MODE=auto

# Optional. Set this only when you want direct API key mode.
CODEBUDDY_API_KEY=

# Runtime behavior
CODEBUDDY_LOG_LEVEL=INFO
CODEBUDDY_ROTATION_COUNT=1

# Advanced optional overrides
# CODEBUDDY_API_ENDPOINT=https://copilot.tencent.com
# CODEBUDDY_MODELS=
# CODEBUDDY_CREDS_DIR=.codebuddy_creds
